import { PrismaClient } from '@prisma/client';
import { Metadata } from 'next';
import { notFound } from 'next/navigation';

const prisma = new PrismaClient();

interface Props {
  params: { slug: string };
}

// 1. HÀM GEN METADATA ĐỘNG (Hệ thống tự gọi khi Bot Google quét qua)
export async function generateMetadata({ params }: Props): Promise<Metadata> {
  const product = await prisma.product.findUnique({
    where: { slug: params.slug },
  });

  if (!product) return {};

  // Tối ưu Title: Đảm bảo độ dài từ 65 - 69 ký tự (Thêm hậu tố nếu thiếu)
  let seoTitle = `${product.name} | Chính Hãng, Giá Tốt Nhất`;
  if (seoTitle.length < 65) {
    seoTitle = seoTitle.padEnd(65, ' '); // Hoặc viết thêm text cho tự nhiên
  } else if (seoTitle.length > 69) {
    seoTitle = seoTitle.substring(0, 66) + '...';
  }

  // Tối ưu Description: Cắt ngắn dưới 165 ký tự để tránh bị dấu "..." trên Google
  const seoDescription = product.description.length > 160 
    ? product.description.substring(0, 157) + '...' 
    : product.description;

  return {
    title: seoTitle.trim(),
    description: seoDescription,
  };
}

// 2. GIAO DIỆN TRANG CHI TIẾT SẢN PHẨM
export default async function ProductDetailPage({ params }: Props) {
  const product = await prisma.product.findUnique({
    where: { slug: params.slug },
  });

  if (!product) {
    notFound();
  }

  return (
    <main className="container mx-auto p-4">
      {/* ĐÚNG MỘT THẺ H1 DUY NHẤT CHO TÊN SẢN PHẨM */}
      <h1 className="text-3xl font-bold mb-4">{product.name}</h1>
      
      <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          {/* ẢNH SẢN PHẨM CÓ THUỘC TÍNH ALT CHUẨN SEO */}
          <img 
            src={product.imageUrl} 
            alt={`${product.name} chính hãng chất lượng cao`} 
            className="w-full rounded-lg"
          />
        </div>
        
        <div>
          {/* CÁC THẺ H2, H3 ĐỂ PHÂN CẤP NỘI DUNG LOGIC */}
          <h2 className="text-xl font-semibold mt-6 mb-2">Thông số kỹ thuật</h2>
          <p className="text-gray-700 mb-4">{product.specifications}</p>

          <h2 className="text-xl font-semibold mt-6 mb-2">Mô tả sản phẩm</h2>
          <p className="text-gray-700">{product.description}</p>
          
          <h3 className="text-lg font-medium mt-4 mb-2">Chính sách bảo hành</h3>
          <p className="text-gray-600 text-sm">Bảo hành 12 tháng đổi mới nếu có lỗi từ nhà sản xuất.</p>
        </div>
      </div>
    </main>
  );
}
