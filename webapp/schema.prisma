generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       Int      @id @default(autoincrement())
  name     String
  email    String   @unique
  password String
  role     String   @default("Customer")
  orders   Order[]
}

model Category {
  id       Int        @id @default(autoincrement())
  name     String
  slug     String     @unique
  parentId Int?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]
}

model Tag {
  id       Int       @id @default(autoincrement())
  name     String
  slug     String    @unique
  products Product[]
}

model Product {
  id         Int           @id @default(autoincrement())
  title      String
  price      Float
  categoryId Int
  category   Category      @relation(fields: [categoryId], references: [id])
  tags       Tag[]
  orders     OrderDetail[]

  slug         String        @unique @default(uuid())
  description  String?      
  image        String?
  imageAlt     String?

    sku          String?       @unique 
  regularPrice Float?        
  salePrice    Float?        
  stockStatus  String        @default("In stock") 
  stockQty     Int           @default(0) 
  attributes   Attribute[]
  variations   Variation[]
}

model Order {
  id          Int           @id @default(autoincrement())
  userId      Int
  user        User          @relation(fields: [userId], references: [id])
  totalAmount Float
  status      String        @default("Pending")
  products    OrderDetail[]
}

model OrderDetail {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Attribute {
  id        Int         @id @default(autoincrement())
  name      String      
  productId Int
  product   Product     @relation(fields: [productId], references: [id])
  variations Variation[]
}
model Variation {
  id           Int        @id @default(autoincrement())
  value        String     
  sku          String     @unique
  regularPrice Float?
  salePrice    Float?
  stockStatus  String     @default("In stock")
  stockQty     Int        @default(0)
  productId    Int
  product      Product    @relation(fields: [productId], references: [id])
  attributeId  Int
  attribute    Attribute  @relation(fields: [attributeId], references: [id])
}