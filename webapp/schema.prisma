generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       Int      @id @default(autoincrement())
  name     String
  email    String   @unique
  password String
  role     String   @default("Customer")
}

model Category {
  id       Int        @id @default(autoincrement())
  name     String
  slug     String     @unique
  parentId Int?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]
}

model Tag {
  id       Int       @id @default(autoincrement())
  name     String
  slug     String    @unique
  products Product[]
}

model Product {
  id             Int         @id @default(autoincrement())
  title          String
  slug           String      @unique
  price          Float
  imageUrl       String?     @default("/vot-cau-long-yonex.jpg")
  description    String?     @default("Mô tả sản phẩm đang cập nhật")
  specifications String?     @default("Thông số kỹ thuật đang cập nhật")
  categoryId     Int
  category       Category    @relation(fields: [categoryId], references: [id])
  tags           Tag[]
  orderItems     OrderItem[]

  // Incoming fields from remote develop
  image        String?
  imageAlt     String?
  sku          String?       @unique 
  regularPrice Float?        
  salePrice    Float?        
  stockStatus  String        @default("In stock") 
  stockQty     Int           @default(0) 
  attributes   Attribute[]
  variations   Variation[]
}

model Order {
  id            String      @id
  customerName  String
  email         String
  phone         String
  address       String
  paymentMethod String
  status        String      @default("Pending")
  total         Float
  createdAt     DateTime    @default(now())
  items         OrderItem[]
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     String
  productId   Int
  variationId Int?
  quantity    Int
  price       Float
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
}

model Attribute {
  id        Int         @id @default(autoincrement())
  name      String      
  productId Int
  product   Product     @relation(fields: [productId], references: [id])
  variations Variation[]
}

model Variation {
  id           Int        @id @default(autoincrement())
  value        String     
  sku          String     @unique
  regularPrice Float?
  salePrice    Float?
  stockStatus  String     @default("In stock")
  stockQty     Int        @default(0)
  productId    Int
  product      Product    @relation(fields: [productId], references: [id])
  attributeId  Int
  attribute    Attribute  @relation(fields: [attributeId], references: [id])
}